#!/usr/bin/env bash
# mygemini — Gemini CLI wrapper for AICOMM
# Runs gemini with all passed arguments, then emits the end marker
# so the aicomm daemon knows the response is complete.
set -euo pipefail

if ! command -v gemini &>/dev/null; then
  echo "ERROR: 'gemini' not found in PATH. Install Gemini CLI first." >&2
  printf '\n###AICOMM_END###\n'
  exit 1
fi

gemini --prompt "$@" 2>/tmp/aicomm-gemini-stderr.log || true
printf '\n###AICOMM_END###\n'
