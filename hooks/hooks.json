{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/startup.mjs\"",
            "timeout": 5000,
            "async": true
          }
        ]
      }
    ]
  }
}
